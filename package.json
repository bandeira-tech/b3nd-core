  "author": "B3nd",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/bandeira-tech/b3nd-core" },
  "bugs": { "url": "https://github.com/bandeira-tech/b3nd-core/issues" },
  "homepage": "https://github.com/bandeira-tech/b3nd-core#readme",
  "dependencies": {
    "canonicalize": "^2.0.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.1"
  },
  "publishConfig": { "access": "public" }
