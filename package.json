{
  "name": "@bandeira-tech/b3nd-core",
  "version": "0.9.4",
  "description": "B3nd Core — framework foundation: types, encoding, clients, rig, network",
  "type": "module",
  "main": "./dist/src/mod.js",
  "module": "./dist/src/mod.js",
  "types": "./dist/src/mod.d.ts",
  "exports": {
    ".": { "import": "./dist/src/mod.js", "types": "./dist/src/mod.d.ts" },
    "./types": { "import": "./dist/types/mod.js", "types": "./dist/types/mod.d.ts" },
    "./encoding": { "import": "./dist/encoding/mod.js", "types": "./dist/encoding/mod.d.ts" },
    "./binary": { "import": "./dist/binary/mod.js", "types": "./dist/binary/mod.d.ts" },
    "./network": { "import": "./dist/network/mod.js", "types": "./dist/network/mod.d.ts" },
    "./client-console": { "import": "./dist/client-console/mod.js", "types": "./dist/client-console/mod.d.ts" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
