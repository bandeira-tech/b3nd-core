{
  "name": "@bandeira-tech/b3nd-core",
  "version": "0.19.0",
  "description": "B3nd Core — framework foundation: types, encoding, clients, rig, network, hash, encrypt",
  "exports": {
    ".": "./mod.ts",
    "./types": "./src/types/types.ts",
    "./url": "./src/url/url.ts",
    "./encoding": "./src/encoding/encoding.ts",
    "./hash": "./src/hash/hash.ts",
    "./encrypt": "./src/encrypt/mod.ts",
    "./network": "./src/network/mod.ts",
    "./rig": "./src/rig/mod.ts",
    "./identity": "./src/rig/identity.ts",
    "./client-console": "./src/client-console/mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "canonicalize": "npm:canonicalize@2.0.0"
  },
  "tasks": {
    "check": "deno check mod.ts src/rig/mod.ts",
    "test": "deno test --allow-all src/",
    "build:npm": "deno run -A scripts/build-npm.ts"
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable",
      "deno.ns"
    ]
  },
  "publish": {
    "exclude": [
      "!_vendor/",
      "src/testing/",
      "src/**/*.test.ts",
      "src/**/*_test.ts",
      "src/**/README.md",
      "tests/",
      "node_modules/",
      ".env*",
      "*.lock"
    ]
  }
}
