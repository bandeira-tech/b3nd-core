{
  "name": "@bandeira-tech/b3nd-core",
  "version": "0.18.0",
  "description": "B3nd Core — framework foundation: types, encoding, clients, rig, network, hash, encrypt",
  "exports": {
    ".": "./mod.ts",
    "./types": "./libs/b3nd-core/types.ts",
    "./url": "./libs/b3nd-core/url.ts",
    "./encoding": "./libs/b3nd-core/encoding.ts",
    "./hash": "./hash.ts",
    "./encrypt": "./encrypt.ts",
    "./network": "./libs/b3nd-network/mod.ts",
    "./rig": "./rig.ts",
    "./identity": "./libs/b3nd-rig/identity.ts",
    "./client-console": "./libs/b3nd-client-console/mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "canonicalize": "npm:canonicalize@2.0.0"
  },
  "tasks": {
    "check": "deno check mod.ts rig.ts",
    "test": "deno test --allow-all libs/",
    "build:npm": "deno run -A scripts/build-npm.ts"
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable",
      "deno.ns"
    ]
  },
  "publish": {
    "exclude": [
      "!_vendor/",
      "libs/b3nd-testing/",
      "libs/**/*.test.ts",
      "libs/**/*_test.ts",
      "libs/**/README.md",
      "libs/**/deno.json",
      "tests/",
      "node_modules/",
      ".env*",
      "*.test.ts",
      "*.lock"
    ]
  }
}
