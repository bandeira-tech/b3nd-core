{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist"
  },
  "include": [
    "src/*.ts",
    "./libs/b3nd-core/**/*.ts",
    "./libs/b3nd-rig/**/*.ts",
    "./libs/b3nd-network/**/*.ts",
    "./libs/b3nd-client-memory/**/*.ts",
    "./libs/b3nd-client-http/**/*.ts",
    "./libs/b3nd-client-ws/**/*.ts",
    "./libs/b3nd-client-console/**/*.ts",
    "./libs/b3nd-client-grpc/**/*.ts",
    "./libs/b3nd-server-http/**/*.ts",
    "./libs/b3nd-server-grpc/**/*.ts",
    "./libs/b3nd-proto/**/*.ts",
    "./libs/b3nd-testing/**/*.ts",
    "./libs/b3nd-encrypt/**/*.ts"
  ]
}
